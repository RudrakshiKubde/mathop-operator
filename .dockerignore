# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include Go source files (but not *_test.go)
!**/*.go
**/*_test.go

# Re-include Go module files
!go.mod
!go.sum

# Re-include the mock server script
!mock_server.py

# Exclude the nested function-httptask project from the build context
function-httptask/
!function-httptask/mock_server_unused_placeholder  # (no-op, just documenting intent)